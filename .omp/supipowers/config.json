{
  "version": "1.0.0",
  "quality": {
    "gates": {
      "lsp-diagnostics": {
        "enabled": true
      },
      "ai-review": {
        "enabled": true,
        "depth": "deep"
      }
    }
  },
  "lsp": {
    "setupGuide": true
  },
  "notifications": {
    "verbosity": "normal"
  },
  "qa": {
    "framework": null,
    "e2e": false
  },
  "release": {
    "channels": [
      "github",
      "npm"
    ]
  },
  "contextMode": {
    "enabled": true,
    "compressionThreshold": 4096,
    "blockHttpCommands": true,
    "routingInstructions": true,
    "eventTracking": true,
    "compaction": true,
    "llmSummarization": false,
    "llmThreshold": 16384,
    "enforceRouting": true
  },
  "mcp": {
    "closeSessionsOnExit": false
  }
}
