{
  "version": "1.0.0",
  "defaultProfile": "thorough",
  "orchestration": {
    "maxParallelAgents": 3,
    "maxFixRetries": 2,
    "maxNestingDepth": 2,
    "modelPreference": "auto",
    "taskTimeout": 600000
  },
  "lsp": {
    "setupGuide": true
  },
  "notifications": {
    "verbosity": "normal"
  },
  "qa": {
    "framework": null,
    "command": null,
    "e2e": false
  },
  "release": {
    "channels": [
      "github",
      "npm"
    ],
    "pipeline": "npm"
  },
  "contextMode": {
    "enabled": true,
    "compressionThreshold": 4096,
    "blockHttpCommands": true,
    "routingInstructions": true,
    "eventTracking": true,
    "compaction": true,
    "llmSummarization": false,
    "llmThreshold": 16384,
    "enforceRouting": true
  },
  "mcp": {
    "closeSessionsOnExit": false
  }
}
