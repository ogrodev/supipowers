{
  "name": "supipowers",
  "version": "0.7.11",
  "description": "OMP-native workflow extension inspired by supipowers.",
  "type": "module",
  "scripts": {
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "test:watch": "vitest",
    "build": "tsc -p tsconfig.build.json"
  },
  "keywords": [
    "omp-extension",
    "workflow",
    "agent",
    "supipowers"
  ],
  "license": "MIT",
  "bin": {
    "supipowers": "bin/install.mjs"
  },
  "files": [
    "src",
    "skills",
    "bin",
    "README.md",
    "LICENSE"
  ],
  "dependencies": {
    "@clack/prompts": "^0.10.0"
  },
  "peerDependencies": {
    "@oh-my-pi/pi-coding-agent": "*",
    "@oh-my-pi/pi-tui": "*",
    "@sinclair/typebox": "*"
  },
  "devDependencies": {
    "@oh-my-pi/pi-coding-agent": "latest",
    "@oh-my-pi/pi-tui": "latest",
    "@sinclair/typebox": "^0.34.48",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.0.0",
    "better-sqlite3": "^12.8.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.0"
  },
  "omp": {
    "extensions": [
      "./src/index.ts"
    ],
    "skills": [
      "./skills"
    ]
  }
}
